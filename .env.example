# ── Optional GitHub Access ────────────────────────────────────────────────────
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# REFACTOR_SCOUT_API_KEY_HASH=
# REFACTOR_SCOUT_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
REFACTOR_SCOUT_DB_PATH=refactor-scout.db
REFACTOR_SCOUT_PORT=8090

# ── Filesystem scan safety ────────────────────────────────────────────────────
# Restrict scans to a path list such as /home/you/code:/srv/repos
# REFACTOR_SCOUT_ALLOWED_ROOTS=/home/you/code
# Allow authenticated remote clients to trigger filesystem scans
# REFACTOR_SCOUT_ALLOW_REMOTE_FS=true

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
